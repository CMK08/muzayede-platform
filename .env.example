###############################################################################
# Muzayede Platform — Environment Variables
# Copy this file to .env and fill in the values
###############################################################################

# =============================================================================
# General
# =============================================================================
NODE_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=pretty
PORT=3000

# =============================================================================
# PostgreSQL
# =============================================================================
DATABASE_URL=postgresql://muzayede:muzayede_dev_2026@localhost:5432/muzayede_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=muzayede:

# =============================================================================
# MongoDB
# =============================================================================
MONGODB_URL=mongodb://muzayede:muzayede_dev_2026@localhost:27017/muzayede_dev?authSource=admin

# =============================================================================
# Kafka
# =============================================================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=muzayede-dev
KAFKA_GROUP_ID=muzayede-dev-group
KAFKA_SSL=false

# =============================================================================
# Elasticsearch
# =============================================================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# =============================================================================
# MinIO / S3
# =============================================================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=muzayede_minio
S3_SECRET_KEY=muzayede_minio_2026
S3_BUCKET_MEDIA=muzayede-media
S3_BUCKET_STATIC=muzayede-static
S3_BUCKET_BACKUPS=muzayede-backups
S3_REGION=eu-central-1
S3_FORCE_PATH_STYLE=true

# =============================================================================
# Authentication & Security
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# =============================================================================
# OAuth2 Providers
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# =============================================================================
# Email (SMTP)
# =============================================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@muzayede.com
SMTP_SECURE=false

# =============================================================================
# SMS
# =============================================================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# Push Notifications
# =============================================================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# =============================================================================
# Payment Gateway
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# =============================================================================
# CDN / CloudFront
# =============================================================================
CDN_URL=http://localhost:9000
CLOUDFRONT_DISTRIBUTION_ID=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_PATH=

# =============================================================================
# API Gateway
# =============================================================================
API_GATEWAY_URL=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3080

# =============================================================================
# Service URLs (internal communication)
# =============================================================================
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
AUCTION_SERVICE_URL=http://localhost:3003
BID_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006
SEARCH_SERVICE_URL=http://localhost:3007
MEDIA_SERVICE_URL=http://localhost:3008
CATEGORY_SERVICE_URL=http://localhost:3009
ANALYTICS_SERVICE_URL=http://localhost:3010
WEBSOCKET_SERVICE_URL=http://localhost:3011
ADMIN_SERVICE_URL=http://localhost:3012
SCHEDULER_SERVICE_URL=http://localhost:3013

# =============================================================================
# WebSocket
# =============================================================================
WS_PORT=3011
WS_PATH=/ws
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=5000

# =============================================================================
# Observability
# =============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=muzayede-platform
METRICS_ENABLED=true
TRACING_ENABLED=true
TRACING_SAMPLE_RATE=1.0

# =============================================================================
# Sentry (Error Tracking)
# =============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_LIVE_AUCTION=true
FEATURE_BUY_NOW=true
FEATURE_RESERVE_PRICE=true
FEATURE_AUTO_BID=true
FEATURE_MULTI_CURRENCY=false

# =============================================================================
# Auction Settings
# =============================================================================
AUCTION_MIN_BID_INCREMENT=1.00
AUCTION_SNIPE_PROTECTION_SECONDS=120
AUCTION_MAX_DURATION_DAYS=30
AUCTION_COMMISSION_RATE=0.05

# =============================================================================
# File Upload
# =============================================================================
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_MAX_FILES=10
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,video/mp4

# =============================================================================
# Encryption
# =============================================================================
ENCRYPTION_KEY=your-32-byte-encryption-key-here
ENCRYPTION_ALGORITHM=aes-256-gcm
