PORT=3006
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/muzayede?schema=public
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092

# Email (AWS SES)
AWS_SES_REGION=eu-central-1
AWS_SES_ACCESS_KEY=your-access-key
AWS_SES_SECRET_KEY=your-secret-key
EMAIL_FROM=noreply@muzayede.com

# SMS
SMS_PROVIDER=netgsm
NETGSM_USERNAME=your-username
NETGSM_PASSWORD=your-password

# Push Notifications
FCM_PROJECT_ID=your-project-id
FCM_PRIVATE_KEY=your-private-key
FCM_CLIENT_EMAIL=your-client-email
APNS_KEY_ID=your-key-id
APNS_TEAM_ID=your-team-id
