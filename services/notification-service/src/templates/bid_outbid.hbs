<!DOCTYPE html>
<html>
<head><meta charset="utf-8"></head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 0;">
  <div style="background-color: #1a1a2e; padding: 20px; text-align: center;">
    <h1 style="color: #e94560; margin: 0;">MUZAYEDE</h1>
  </div>

  <div style="padding: 30px; background-color: #ffffff;">
    <h2 style="color: #e94560;">Teklifiniz Gecildi!</h2>

    <p style="color: #333; line-height: 1.6;">
      Sayin {{firstName}}, <strong>"{{auctionTitle}}"</strong> muzayedesindeki
      teklifiniz baska bir kullanici tarafindan gecildi.
    </p>

    <div style="background-color: #fff3cd; padding: 15px; border-radius: 8px; border-left: 4px solid #ffc107; margin: 20px 0;">
      <p style="margin: 0; color: #856404;">
        <strong>Sizin teklifiniz:</strong> {{yourBid}} TL<br>
        <strong>Guncel en yuksek teklif:</strong> {{currentPrice}} TL<br>
        <strong>Kalan sure:</strong> {{timeRemaining}}
      </p>
    </div>

    <a href="{{auctionUrl}}" style="display: inline-block; background-color: #e94560; color: white; padding: 14px 28px; text-decoration: none; border-radius: 6px; font-weight: bold;">
      Yeni Teklif Ver
    </a>
  </div>

  <div style="padding: 20px; text-align: center; font-size: 12px; color: #999; background-color: #f0f0f0;">
    <p>Muzayede Platform &copy; 2026</p>
  </div>
</body>
</html>
