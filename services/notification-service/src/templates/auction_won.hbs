<!DOCTYPE html>
<html>
<head><meta charset="utf-8"></head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 0;">
  <div style="background-color: #1a1a2e; padding: 20px; text-align: center;">
    <h1 style="color: #e94560; margin: 0;">MUZAYEDE</h1>
  </div>

  <div style="padding: 30px; background-color: #ffffff;">
    <h2 style="color: #28a745;">Tebrikler, {{firstName}}!</h2>

    <p style="color: #333; line-height: 1.6;">
      <strong>"{{auctionTitle}}"</strong> muzayedesini basariyla kazandiniz!
    </p>

    <div style="background-color: #d4edda; padding: 15px; border-radius: 8px; border-left: 4px solid #28a745; margin: 20px 0;">
      <p style="margin: 0; color: #155724;">
        <strong>Kazanan teklif:</strong> {{winningAmount}} TL<br>
        <strong>Muzayede:</strong> {{auctionTitle}}<br>
        <strong>Satici:</strong> {{sellerName}}
      </p>
    </div>

    <p style="color: #333; line-height: 1.6;">
      Lutfen 48 saat icinde odemenizi tamamlayin. Odeme yapilmadiginda
      muzayede iptal edilebilir.
    </p>

    <a href="{{paymentUrl}}" style="display: inline-block; background-color: #28a745; color: white; padding: 14px 28px; text-decoration: none; border-radius: 6px; font-weight: bold;">
      Odemeye Git
    </a>
  </div>

  <div style="padding: 20px; text-align: center; font-size: 12px; color: #999; background-color: #f0f0f0;">
    <p>Muzayede Platform &copy; 2026</p>
  </div>
</body>
</html>
